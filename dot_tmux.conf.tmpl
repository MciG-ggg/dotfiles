# ==================== 通用 ====================
set -g mouse on
# 开启终端真彩色支持
set -g default-terminal "tmux-256color"

# 确保 tmux 传递颜色设置
set -ga terminal-overrides ",*256col*:Tc"

# ==================== Prefix 与快捷键 ====================
# 明确写入本机实际使用的 prefix/常用绑定,避免只依赖插件自动注入。
unbind-key -q C-b
set -g prefix C-a
bind-key C-a send-prefix

# 窗口切换/配置重载(tmux-sensible 常见绑定,这里显式固定)
bind-key a last-window
bind-key b last-window
bind-key C-p previous-window
bind-key C-n next-window
bind-key r source-file ~/.tmux.conf \; display-message "tmux config reloaded"
bind-key R source-file ~/.tmux.conf \; display-message "Sourced ~/.tmux.conf!"

# 帮助/快捷键总览
# tmux 默认 prefix+? 是 list-keys -N,只显示带 note 的键;这里改成完整 key table。
bind-key ? list-keys
# 保留 tmux 默认的按键查找帮助。
bind-key / command-prompt -k -p key { list-keys -1N "%%" }

# 普通浮动 shell 窗口
# F 在屏幕中央打开一个 80% x 80% popup,退出 shell 后自动关闭。
bind-key F display-popup -E -w 80% -h 80%

# pane 导航与大小调整(tmux-pain-control 常见绑定,这里显式固定)
bind-key h select-pane -L
bind-key C-h select-pane -L
bind-key j select-pane -D
bind-key C-j select-pane -D
bind-key k select-pane -U
bind-key C-k select-pane -U
bind-key l select-pane -R
bind-key C-l select-pane -R
bind-key -r H resize-pane -L 5
bind-key -r J resize-pane -D 5
bind-key -r K resize-pane -U 5
bind-key -r L resize-pane -R 5

# split/new-window 保持当前目录
bind-key | split-window -h -c "#{pane_current_path}"
bind-key \\ split-window -fh -c "#{pane_current_path}"
bind-key - split-window -v -c "#{pane_current_path}"
bind-key _ split-window -fv -c "#{pane_current_path}"
bind-key % split-window -h -c "#{pane_current_path}"
bind-key '"' split-window -v -c "#{pane_current_path}"
bind-key c new-window -c "#{pane_current_path}"

# 窗口位置移动
bind-key -r < swap-window -d -t -1
bind-key -r > swap-window -d -t +1

# TPM / resurrect / yank 插件快捷键显式声明。
# 这些脚本由对应插件提供;新机器需先安装 TPM 插件后才可执行。
bind-key I run-shell ~/.tmux/plugins/tpm/bindings/install_plugins
bind-key U run-shell ~/.tmux/plugins/tpm/bindings/update_plugins
bind-key M-u run-shell ~/.tmux/plugins/tpm/bindings/clean_plugins
bind-key C-s run-shell ~/.tmux/plugins/tmux-resurrect/scripts/save.sh
bind-key C-r run-shell ~/.tmux/plugins/tmux-resurrect/scripts/restore.sh
bind-key y run-shell -b ~/.tmux/plugins/tmux-yank/scripts/copy_line.sh
bind-key Y run-shell -b ~/.tmux/plugins/tmux-yank/scripts/copy_pane_pwd.sh

# agent-cockpit popup 快捷键
# C 打开主控弹窗;S 打开搜索弹窗。仅在脚本存在时绑定,避免 Linux 服务器未安装 cockpit 时覆盖默认键。
if-shell 'test -x "$HOME/.tmux/plugins/agent-cockpit/scripts/popup.sh"'   'bind-key C display-popup -E -w 70% -h 90% "$HOME/.tmux/plugins/agent-cockpit/scripts/popup.sh"'
if-shell 'test -x "$HOME/.tmux/plugins/agent-cockpit/scripts/popup.sh"'   'bind-key S display-popup -E -w 70% -h 90% "$HOME/.tmux/plugins/agent-cockpit/scripts/popup.sh --mode=search"'

# copy-mode 剪贴板绑定。按系统选择可用的系统剪贴板工具。
{{ if eq .chezmoi.os "darwin" }}
bind-key -T copy-mode y send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode Y send-keys -X copy-pipe-and-cancel "tmux paste-buffer -p"
bind-key -T copy-mode ! send-keys -X copy-pipe-and-cancel "tr -d '\n' | pbcopy"
bind-key -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi Y send-keys -X copy-pipe-and-cancel "tmux paste-buffer -p"
bind-key -T copy-mode-vi ! send-keys -X copy-pipe-and-cancel "tr -d '\n' | pbcopy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
{{ else if eq .chezmoi.os "linux" }}
if-shell 'command -v wl-copy >/dev/null 2>&1'   'bind-key -T copy-mode y send-keys -X copy-pipe-and-cancel "wl-copy" \; bind-key -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "wl-copy" \; bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "wl-copy" \; bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "wl-copy" \; bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "wl-copy"'
if-shell 'command -v xclip >/dev/null 2>&1'   'bind-key -T copy-mode y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in" \; bind-key -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in" \; bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in" \; bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in" \; bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in"'
if-shell 'command -v xsel >/dev/null 2>&1'   'bind-key -T copy-mode y send-keys -X copy-pipe-and-cancel "xsel --clipboard --input" \; bind-key -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xsel --clipboard --input" \; bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "xsel --clipboard --input" \; bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xsel --clipboard --input" \; bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xsel --clipboard --input"'
bind-key -T copy-mode Y send-keys -X copy-pipe-and-cancel "tmux paste-buffer -p"
bind-key -T copy-mode-vi Y send-keys -X copy-pipe-and-cancel "tmux paste-buffer -p"
{{ end }}

# 注意:不要再手写 setw/-g window-status-style、pane-border-style、
# message-style、status-style 之类的 Dracula 时代硬编码 —— 它们会覆盖
# catppuccin 通过 @catppuccin_window_* / @catppuccin_pane_* 注入的配色,
# 导致主题色跟窗口/pane 边框脱节。所有视觉样式交给 catppuccin。

# ==================== 插件管理 ====================
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'      # 基础优化

# 常用插件
set -g @plugin 'tmux-plugins/tmux-resurrect'     # 会话保存/恢复
set -g @plugin 'tmux-plugins/tmux-continuum'      # 自动保存
set -g @plugin 'tmux-plugins/tmux-yank'           # 系统剪贴板集成
set -g @plugin 'tmux-plugins/tmux-pain-control'   # 面板控制增强

# 主题
set -g @plugin 'catppuccin/tmux'                 # Catppuccin (mocha)

# ==================== Catppuccin 配置 ====================
set -g @catppuccin_flavor "mocha"
set -g @catppuccin_window_status_style "rounded"

# 禁用未使用的内置模块(保留 directory + git + session + host)
set -g @catppuccin_status_application_disable  true
set -g @catppuccin_status_date_time_disable    true
set -g @catppuccin_status_uptime_disable       true

# ==================== TPM 初始化 ====================
# 必须放在 status-right 之前 —— 状态栏里 #{E:@catppuccin_status_*}
# 依赖 catppuccin 加载后才会定义的变量,run tpm 会同步等插件加载完才返回。
if-shell 'test -x "$HOME/.tmux/plugins/tpm/tpm"' 'run-shell "$HOME/.tmux/plugins/tpm/tpm"'

# ==================== status bar 模块布局 ====================
# Catppuccin 模块变量由 TPM 加载主题后生成,所以必须放在 run tpm 之后。
# 左侧放完整 session pill 模块;右侧只保留目录、git、host,避免 session 重复。
set -g status-left "#{E:@catppuccin_status_session}"
set -g status-left-length 80
set -g status-right "#{E:@catppuccin_status_directory}#{E:@catppuccin_status_git}#{E:@catppuccin_status_host}"
set -g status-right-length 250
