" Racket REPL
let s:racket_repl_height = 10
function RacketRepl()
  let filename = expand('%:t')
  cd %:p:h
  exe "belowright " .. s:racket_repl_height .. " split"
  if !exists('g:slime_vimterminal_config')
    let s:bufnr = term_start('racket')
  else
    let s:bufnr = term_start('racket', g:slime_vimterminal_config)
  endif
  call term_sendkeys(s:bufnr, ',enter "' .. filename .. "\"\n")
  call win_gotoid(s:bufnr)
endfunction

function SlimeOverrideConfig()
  if exists('s:bufnr')
    let b:slime_config = {"bufnr": s:bufnr}
  endif
endfunction

command Racket call RacketRepl()
